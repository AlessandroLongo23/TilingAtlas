{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@/lib": ["./lib"],
      "@/lib/*": ["./lib/*"],
      "@/components": ["./components"],
      "@/components/*": ["./components/*"],
      "@/classes": ["./lib/classes"],
      "@/classes/*": ["./lib/classes/*"],
      "@/stores": ["./lib/stores"],
      "@/stores/*": ["./lib/stores/*"],
      "@/utils": ["./lib/utils"],
      "@/utils/*": ["./lib/utils/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
