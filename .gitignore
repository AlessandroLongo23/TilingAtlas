# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# pipeline outputs
pipeline-output/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# parallel-scout crash-resume artifacts
.scout-cache/

# MCP config holds a Supabase PAT — never commit
.mcp.json

# agent/editor litter
*.tmp
*.orig
*.rej

# python artifacts (experiments)
__pycache__/

# thesis figure pipeline intermediates (PDFs are delivered to ../thesis, sources committed)
figures/out/

# claude worktrees (concurrent agent sessions)
.claude/worktrees/

# extended-catalogue chart intermediates (k≥14 per-tiling classify/weight CSVs, ~100+ MB each) —
# regenerable via eu_develop → eu_classify → ctrnact-wtF; the k≤13 slices stay committed, the compact
# envelope summary (ctrnact-weight-envelope-k1-16.csv) captures the result.
experiments/results/ctrnact-symclass-k1-16.csv
experiments/results/ctrnact-weights-exact-k1-16.csv

# native C++ engine — sources (.hpp/.cpp/.ts/Makefile/README) are committed; compiled Mach-O
# binaries and generated traces are not
native-engine/bench
native-engine/bench-fast
native-engine/bench-tf
native-engine/difftest
native-engine/fill-server
native-engine/*.o
native-engine/difftrace.txt

# throwaway patch-growth galleries (the generating scripts are marked THROWAWAY)
tmp-patches/
tmp-star-patches/

# scratch / intermediate data (underscore prefix — regenerable, not source-of-truth)
experiments/results/_*
figures/data/_*-tmp.json

# raw figure-trace probe output (regenerable via the FIG_NS probe); the curated per-example
# slice under figures/traces/<name>/ is committed as the figures' data source
figures/traces/_probe/
